# Build output
out/
build/
*.o
*.obj
*.a
*.lib
*.exe
*.ilk
*.pdb

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake

# IDE
.vs/
.vscode/
*.user

# Exception: the shipped, statically-linked release binaries ARE tracked
# (so the repo is runnable without a build). They live only in release/.
!release/
!release/*.exe

# NDA firmware packages must NEVER be tracked (also not inside release/)
*.mchpkg

# NDA local reference dossier: the ENTIRE EVB/ tree (datasheets, user guides,
# schematic, firmware, captures, vendor SDK) must never be tracked. It is local
# only — see CLAUDE.md "Local reference material (NDA)".
EVB/

# Local diagnostic artifacts (Wireshark captures + the demo's event log)
logs/
clickdemo-events*.csv

# Generated preview images (e.g. tools/make_cube_video.py --preview)
*.preview.png

# Vendored bridge firmware (firmware/t1s_100baset_bridge): regenerable MCC
# backups + build outputs (out/ and build/ are already covered globally above).
firmware/**/mcc_backup/
# CMake/Ninja working dir from the shell build (build.bat) + its generated DB.
_build/
firmware/**/_build/
firmware/**/compile_commands.json
# MPLAB MDB trace logs from flash.py
firmware/**/defmplabxtrace.log*
